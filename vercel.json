
{
  "version": 2,
  "builds": [
    {
      "src": "index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/generate",
      "dest": "index.js"
    },
    {
      "src": "/docs.html",
      "dest": "/public/docs.html"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}
